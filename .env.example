# .env.example — copy to .env and fill in your real values
# Never commit .env to git

# ── Square (payments / deposits) ──────────────────────────────────
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_LOCATION_ID=your_square_location_id_here
SQUARE_ENV=production

# ── OpenAI (AI chat widget) ────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your_key_here

# ── Formspree (contact form emails) ──────────────────────────────────# Your Formspree form ID (the part after /f/ in your Formspree URL)
FORMSPREE_ENDPOINT=xzdjpakd

# ── Mailchimp (newsletter / Inner Circle) ──────────────────────────────────MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_LIST_ID=your_audience_list_id_here
MAILCHIMP_SERVER=us1

# ── Google Analytics ──────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── App ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production